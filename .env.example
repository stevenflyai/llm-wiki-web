# ================================================================
# LLM Wiki — 配置文件模板
# 使用方式：cp .env.example .env，然后填入你要用的 Provider 的 Key
#
# Provider 自动检测顺序：custom → anthropic → azure → openai → ollama
# 只需填入一个 Provider 的 API Key，其余保持注释即可。
# ================================================================

# （可选）强制指定 Provider，留空则按上方顺序自动检测
# 可选值：anthropic / openai / ollama / custom
LLM_PROVIDER=

# ----------------------------------------------------------------
# Anthropic Claude — 填入 Key 即启用
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # 使用企业代理/镜像时取消注释并修改

# ----------------------------------------------------------------
# Azure OpenAI — 填入 Key + Endpoint + Deployment 即启用
# ----------------------------------------------------------------
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/v1
# AZURE_OPENAI_DEPLOYMENT=gpt-4o                  # deployment name
# AZURE_OPENAI_API_VERSION=2026-03-05             # API 版本

# ----------------------------------------------------------------
# OpenAI — 填入 Key 即启用
# ----------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1      # 使用代理时取消注释

# ----------------------------------------------------------------
# 第三方 OpenAI 兼容服务（DeepSeek / 通义千问 / Moonshot 等）
# 三项都填才生效，优先级高于 Anthropic 和 OpenAI
# 示例（DeepSeek）：
# ----------------------------------------------------------------
# CUSTOM_BASE_URL=https://api.deepseek.com/v1
# CUSTOM_API_KEY=sk-...
# CUSTOM_MODEL=deepseek-chat

# ----------------------------------------------------------------
# Ollama 本地模型（无需 Key，以上均未配置时自动使用）
# ----------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b

# ----------------------------------------------------------------
# PDF 提取 & 编译行为（一般不需要改）
# ----------------------------------------------------------------
PDF_BACKEND=pymupdf4llm       # 留空自动检测：pymupdf4llm > markitdown > pdfminer > pypdf
PDF_WORKERS=4                  # 并行提取 PDF 的线程数
PDF_MAX_CHARS=240000           # 每次发给 LLM 的最大字符数
LLM_TIMEOUT=120                # 请求超时（秒）
